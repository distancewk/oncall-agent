# Copy to .env and replace every placeholder before running docker compose.
DASHSCOPE_API_KEY=replace-with-dashscope-key
APP_API_TOKEN=replace-with-long-random-api-token
APP_WEBHOOK_SECRET=replace-with-long-random-webhook-secret
POSTGRES_PASSWORD=replace-with-long-random-postgres-password
APP_INCIDENT_JDBC_PASSWORD=replace-with-long-random-postgres-password
MINIO_ROOT_USER=replace-with-minio-user
MINIO_ROOT_PASSWORD=replace-with-long-random-minio-password
